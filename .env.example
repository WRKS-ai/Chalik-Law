# ── Calendar Provider ─────────────────────────────────────────
# Options: ghl | calendly
CALENDAR_PROVIDER=ghl

# ── CRM / Lead Capture Provider ───────────────────────────────
# Options: ghl | hubspot | email
CRM_PROVIDER=ghl

# ── GHL (used for both calendar + CRM if applicable) ──────────
GHL_API_KEY=
GHL_LOCATION_ID=
# Optional — only needed if creating pipeline opportunities
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=

# ── Calendly (if CALENDAR_PROVIDER=calendly) ──────────────────
CALENDLY_API_KEY=
# Event type UUID — from your Calendly event type URL
CALENDLY_EVENT_TYPE_UUID=

# ── HubSpot (if CRM_PROVIDER=hubspot) ─────────────────────────
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# ── Email fallback (if CRM_PROVIDER=email) ────────────────────
NOTIFICATION_EMAIL=
