---
const phone = "(555) 555-5555";
const phoneHref = "tel:+15555555555";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Chalik & Chalik | Personal Injury Attorneys</title>
    <meta name="description" content="Injured? You deserve justice. Chalik & Chalik fights for maximum compensation. Free consultation — no fee unless we win." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- Header -->
    <header class="header">
      <div class="container">
        <div class="logo">CHALIK <span>&amp;</span> CHALIK</div>
        <a href={phoneHref} class="header-cta">Call Now</a>
      </div>
    </header>

    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <p class="hero-eyebrow">South Florida Personal Injury Attorneys</p>
        <h1>Injured?<br />You Deserve <span class="highlight">Justice.</span></h1>
        <p class="hero-sub">Watch this short video to learn how we fight for the compensation you deserve&nbsp;&mdash; at no cost to you unless we win.</p>
      </div>
    </section>

    <!-- Video -->
    <section class="video-section">
      <div class="container">
        <div class="video-wrapper">
          <div class="video-placeholder">
            <div class="play-btn">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                <circle cx="32" cy="32" r="31" stroke="white" stroke-width="2" />
                <polygon points="26,20 26,44 46,32" fill="white" />
              </svg>
            </div>
            <p class="video-coming">Video Coming Soon</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Bar -->
    <section class="trust">
      <div class="container">
        <div class="trust-grid">
          <div class="trust-item">
            <div class="trust-number">30+</div>
            <div class="trust-label">Years of Experience</div>
          </div>
          <div class="trust-item">
            <div class="trust-number">$100M+</div>
            <div class="trust-label">Recovered for Clients</div>
          </div>
          <div class="trust-item">
            <div class="trust-number">5,000+</div>
            <div class="trust-label">Cases Handled</div>
          </div>
          <div class="trust-item">
            <div class="trust-number">$0</div>
            <div class="trust-label">No Fee Unless We Win</div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <h2>Don't Wait. Get the Help You Deserve&nbsp;Today.</h2>
        <p>Our team is standing by to give you a free, no-obligation case review.</p>
        <a href={phoneHref} class="cta-button">
          <svg class="phone-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          Call {phone}
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-logo">CHALIK &amp; CHALIK</div>
        <p class="disclaimer">The information on this website is for general information purposes only. Nothing on this site should be taken as legal advice for any individual case or situation. This information is not intended to create, and receipt or viewing does not constitute, an attorney-client relationship. Past results do not guarantee future outcomes.</p>
        <p class="copyright">&copy; {new Date().getFullYear()} Chalik &amp; Chalik. All rights reserved.</p>
      </div>
    </footer>

    <!-- Sticky Mobile CTA -->
    <div class="sticky-cta">
      <a href={phoneHref} class="sticky-cta-button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        Call Now &mdash; Free Consultation
      </a>
    </div>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: #1e293b;
    background: #ffffff;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    width: 100%;
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* Header */
  .header {
    background: #1B2A4A;
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: 0.05em;
  }

  .logo span { color: #60a5fa; }

  .header-cta {
    display: inline-block;
    background: #2563EB;
    color: #fff;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.875rem;
    transition: background 0.2s;
  }

  .header-cta:hover { background: #1d4ed8; }

  /* Hero */
  .hero {
    background: linear-gradient(135deg, #f0f4ff 0%, #e8ecf8 100%);
    padding: 4rem 0 3rem;
    text-align: center;
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #2563EB;
    margin-bottom: 1rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    color: #1B2A4A;
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .highlight { color: #2563EB; }

  .hero-sub {
    font-size: 1.0625rem;
    color: #475569;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Video */
  .video-section {
    padding: 3rem 0;
    background: #ffffff;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(27, 42, 74, 0.12);
  }

  .video-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(160deg, #1B2A4A 0%, #0f1b33 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    cursor: pointer;
  }

  .play-btn {
    opacity: 0.8;
    transition: opacity 0.2s, transform 0.2s;
  }

  .video-placeholder:hover .play-btn {
    opacity: 1;
    transform: scale(1.08);
  }

  .video-coming {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* Trust Bar */
  .trust {
    padding: 3rem 0;
    background: #f8fafc;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }

  .trust-number {
    font-size: 2rem;
    font-weight: 800;
    color: #1B2A4A;
    line-height: 1.2;
  }

  .trust-label {
    font-size: 0.8125rem;
    color: #64748b;
    margin-top: 0.25rem;
    font-weight: 500;
  }

  /* CTA Section */
  .cta-section {
    padding: 4rem 0;
    text-align: center;
    background: #ffffff;
  }

  .cta-section h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: #1B2A4A;
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    font-size: 1.0625rem;
    color: #475569;
    margin-bottom: 2rem;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #2563EB;
    color: #fff;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.125rem;
    transition: background 0.2s, transform 0.15s;
    box-shadow: 0 4px 14px rgba(37, 99, 235, 0.35);
  }

  .cta-button:hover {
    background: #1d4ed8;
    transform: translateY(-1px);
  }

  .phone-icon { flex-shrink: 0; }

  /* Footer */
  .footer {
    background: #1B2A4A;
    color: #94a3b8;
    padding: 2.5rem 0;
    text-align: center;
  }

  .footer-logo {
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .disclaimer {
    font-size: 0.6875rem;
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto 1rem;
    color: #64748b;
  }

  .copyright {
    font-size: 0.75rem;
    color: #475569;
  }

  /* Sticky Mobile CTA */
  .sticky-cta {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 99;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(8px);
    border-top: 1px solid #e2e8f0;
  }

  .sticky-cta-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    background: #2563EB;
    color: #fff;
    padding: 0.875rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .hero { padding: 3rem 0 2rem; }
    .sticky-cta { display: block; }
    body { padding-bottom: 5rem; }
  }

  @media (max-width: 480px) {
    .trust-number { font-size: 1.5rem; }
    .cta-button { width: 100%; justify-content: center; }
  }
</style>
