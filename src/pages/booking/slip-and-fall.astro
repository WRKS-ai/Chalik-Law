---
// PAGE 2 - BOOKING PAGE
// Route: /booking/slip-and-fall
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalWidget from '../../components/CalWidget.astro';

const CONFIG = {
  metaTitle:    "Book Your Free Case Review | Chalik and Chalik",
  metaDesc:     "Book your free consultation with Chalik and Chalik.",
  clientDomain: "https://chaliklaw.com",
  verticalSlug: "slip-and-fall",
  clientName:   "Chalik and Chalik",
  fbPixelId:    "",

  progressLabel: "Your Case Review Has Been Pre-Approved",
  disclaimer:    "If your accident occurred more than 4 years ago, please do not book a call. Cases outside the statute of limitations cannot be accepted.",

  // Calendar
  calendarId:       "PLACEHOLDER-CALENDAR-ID",
  calendarProvider: "ghl",
  slotDuration:     30,

  year: new Date().getFullYear(),
};

const redirectUrl = `/thank-you/${CONFIG.verticalSlug}`;
---

<BaseLayout
  title={CONFIG.metaTitle}
  description={CONFIG.metaDesc}
  canonical={`${CONFIG.clientDomain}/booking/${CONFIG.verticalSlug}`}
  minimalNav={true}
  minimalFooter={true}
  noChat={true}
>

{CONFIG.fbPixelId && (
  <script slot="head" is:inline define:vars={{ pid: CONFIG.fbPixelId }}>
    window.addEventListener('load',function(){
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init',pid);fbq('track','PageView');
    });
  </script>
)}

<style is:global>
:root{
  --bg:#ffffff;--bg1:#f7f7f8;--bg2:#eeeeef;
  --t0:#0d0d0d;--t1:#444444;--t2:#888888;
  --pu:#1a3a6b;--pu3:#2563EB;
  --ease:cubic-bezier(.4,0,.2,1);
  --sans:'Inter',system-ui,sans-serif;
}
@media(min-width:1025px){
  .page-wrap{padding-top:68px;min-height:100vh;display:flex;flex-direction:column}
  .dc-layout{flex:1;display:grid;grid-template-columns:360px 1fr;gap:48px;max-width:1200px;width:100%;margin:0 auto;padding:0 48px}
  .dc-copy{position:relative}
  .dc-copy-inner{padding:120px 0 40px;display:flex;flex-direction:column}
  .dc-cal{display:flex;flex-direction:column;padding:120px 0 60px 40px}
  .dc-cal-frame{display:block;width:100%}
}
@media(max-width:1024px){
  html{scroll-behavior:smooth}
  .page-wrap{padding-top:68px;flex:1;display:flex;flex-direction:column}
  .dc-layout{display:flex;flex-direction:column}
  .dc-copy-inner{padding:50px 32px 12px;display:flex;flex-direction:column}
  .dc-cal{padding:0 32px 50px;margin-top:-2px}
}
@media(max-width:600px){
  .dc-copy-inner{padding:50px 20px 32px}
  .dc-cal{padding:0 20px 50px}
}
.dc-lbl{font-size:14px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--pu3);display:flex;align-items:center;gap:8px;margin-bottom:22px}
.dc-lbl::before{content:'';width:20px;height:1px;background:var(--pu3);opacity:.5}
.dc-h1{font-size:clamp(28px,3.2vw,44px);font-weight:700;line-height:1.06;letter-spacing:-.038em;margin-bottom:18px;color:var(--t0)}
.dc-h1 em{font-size:1.04em;color:var(--pu3)}
.dc-sub{font-size:18px;color:var(--t1);line-height:1.8;margin-bottom:20px}

.progress-wrap{margin:0 0 22px}
.progress-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
.progress-meta-lbl{font-size:12px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--t2)}
.progress-track{width:100%;height:9px;background:rgba(0,0,0,.08);border-radius:100px;overflow:hidden}
.progress-fill{width:70%;height:100%;border-radius:100px;background:linear-gradient(90deg,#1a3a6b 0%,#2563EB 55%,#60a5fa 100%);position:relative;overflow:hidden}
.progress-fill::before{content:'';position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.18) 0%,transparent 60%);border-radius:100px}
.progress-fill::after{content:'';position:absolute;top:0;left:0;width:60%;height:100%;background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,.38) 50%,transparent 100%);animation:liquid-shine 2.2s ease-in-out infinite}
@keyframes liquid-shine{0%{transform:translateX(-120%)}100%{transform:translateX(260%)}}

.pg-foot{padding:16px 0;border-top:1px solid rgba(0,0,0,.1)}
.pg-foot-inner{display:flex;align-items:center;justify-content:space-between;gap:20px;max-width:1200px;margin:0 auto;padding:0 56px;width:100%}
.pg-foot-legal{font-size:12px;color:rgba(0,0,0,.5)}
.pg-foot-links{display:flex;align-items:center;gap:20px}
.pg-foot-links a{font-size:12px;color:rgba(0,0,0,.5);text-decoration:none;transition:color .15s}
.pg-foot-links a:hover{color:var(--t0)}
@media(max-width:1024px){.pg-foot-inner{padding:0 32px}}
@media(max-width:760px){.pg-foot-inner{padding:0 24px}}
</style>

<div class="page-wrap">
  <div class="dc-layout">
    <div class="dc-copy">
      <div class="dc-copy-inner">
        <div class="progress-wrap">
          <div class="progress-meta">
            <span class="progress-meta-lbl">{CONFIG.progressLabel}</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill"></div>
          </div>
        </div>
        <h1 class="dc-h1">Final Step: <em>Book Your Free Consultation</em></h1>
        <p class="dc-sub"><strong style="color:var(--t0)">Please note:</strong> {CONFIG.disclaimer}</p>
      </div>
    </div>

    <div class="dc-cal" id="book">
      <div class="dc-cal-frame">
        <CalWidget
          calendarId={CONFIG.calendarId}
          provider={CONFIG.calendarProvider}
          slotDuration={CONFIG.slotDuration}
          redirectUrl={redirectUrl}
          passName={true}
          theme="light"
        />
      </div>
    </div>
  </div>

  <footer class="pg-foot">
    <div class="pg-foot-inner">
      <p class="pg-foot-legal">&copy; {CONFIG.year} Chalik &amp; Chalik. All Rights Reserved.</p>
      <div class="pg-foot-links">
        <a href="/privacy-policy">Privacy</a>
        <a href="/terms">Terms</a>
      </div>
    </div>
  </footer>
</div>

</BaseLayout>
