---
// PAGE 4 - THANK YOU (UNQUALIFIED)
// Route: /not-qualified/slip-and-fall
import BaseLayout from '../../layouts/BaseLayout.astro';

const CONFIG = {
  metaTitle:    "Thank You for Reaching Out | Chalik and Chalik",
  clientDomain: "https://chaliklaw.com",
  verticalSlug: "slip-and-fall",
  clientName:   "Chalik and Chalik",
  fbPixelId:    "",

  eyebrow:  "Thank you for reaching out",
  h1:       "We may not be able to take your case right now.",
  sub:      "Cases from accidents that occurred more than 4 years ago are generally outside the statute of limitations in Florida. Here are some resources that may still help you.",

  card1: {
    eyebrow: "Slip & Fall Attorneys",
    title:   "Chalik & Chalik Law Firm",
    desc:    "Visit our website to learn more about how we fight for Florida injury victims and the results we have achieved.",
    href:    "https://chaliklaw.com",
    cta:     "Visit chaliklaw.com",
  },
  card2: {
    eyebrow: "Know Your Rights",
    title:   "Florida Slip and Fall Guide",
    desc:    "Our attorneys explain Florida slip and fall law, what to document, and how to protect your rights after an accident.",
    href:    "https://www.chaliklaw.com/florida-slip-and-fall-accident-lawyer/",
    cta:     "Read the guide",
  },

  bookAnywayText:     "Think you answered the question incorrectly? No problem. You can still request a review below.",
  bookAnywayLinkText: "Request a case review anyway",
  year:               new Date().getFullYear(),
};

const bookAnywayLink = `/watch/${CONFIG.verticalSlug}`;
---

<BaseLayout
  title={CONFIG.metaTitle}
  description=""
  canonical={`${CONFIG.clientDomain}/not-qualified/${CONFIG.verticalSlug}`}
  minimalNav={true}
  minimalFooter={true}
  noChat={true}
>
<meta slot="head" name="robots" content="noindex, nofollow" />
<meta slot="head" property="og:title" content={CONFIG.metaTitle} />
<meta slot="head" property="og:image" content="https://chaliklaw.com/og-walmart-slip-and-fall.jpg" />
<link slot="head" rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link slot="head" rel="icon" href="/favicon-64.png" type="image/png" sizes="64x64" />
<link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
<link slot="head" rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link slot="head" href="https://fonts.googleapis.com/css2?family=Open+Sans+Condensed:wght@700&family=Source+Sans+3:wght@400;600;700;900&display=swap" rel="stylesheet" />

{CONFIG.fbPixelId && (
  <script slot="head" is:inline define:vars={{ pid: CONFIG.fbPixelId }}>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init',pid);fbq('track','PageView');
  </script>
)}

<style is:global>
:root{
  --bg:#ffffff;--bg1:#f7f7f8;--bg2:#eeeeef;
  --t0:#0d0d0d;--t1:#444444;--t2:#888888;
  --navy:#003861;--navy2:#002347;--navy3:#001529;
  --green:#a2cc35;--blue:#0073e5;
  --ease:cubic-bezier(.4,0,.2,1);
  --sans:'Source Sans 3',system-ui,sans-serif;
}
#nav-bg{display:none!important}
#nav{display:none!important}

.c-header{position:fixed;top:0;left:0;right:0;z-index:200;background:var(--navy2);border-bottom:1px solid rgba(255,255,255,.06)}
.c-header-inner{display:flex;align-items:center;justify-content:center;height:72px;max-width:1200px;margin:0 auto;padding:0 48px}
.c-header-logo img{height:60px;width:auto;display:block}
@media(max-width:640px){.c-header-inner{padding:0 20px;height:64px}.c-header-logo img{height:50px}}

.uq-page{min-height:100vh;display:flex;flex-direction:column}
.uq-wrap{flex:1;width:100%;max-width:760px;margin:0 auto;padding:104px 32px 56px;text-align:center;display:flex;flex-direction:column;justify-content:center}
@media(max-width:1024px){.uq-page{min-height:0}.uq-wrap{display:block;padding:104px 32px 60px}}
@media(max-width:640px){.uq-wrap{padding:96px 24px 56px}}

.uq-eyebrow{display:inline-block;font-size:22px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--green);margin-bottom:20px;font-family:'Open Sans Condensed','Source Sans 3',sans-serif}
.uq-h1{font-size:clamp(28px,4vw,46px);font-weight:700;line-height:1.08;letter-spacing:-.035em;color:var(--t0);margin:0 0 18px}
.uq-sub{font-size:clamp(16px,1.5vw,18px);color:var(--t1);line-height:1.7;max-width:600px;margin:0 auto 44px}

.uq-cards{display:grid;grid-template-columns:1fr 1fr;gap:18px;max-width:680px;margin:0 auto 36px;text-align:left}
@media(max-width:640px){.uq-cards{grid-template-columns:1fr}.uq-eyebrow{font-size:16px;letter-spacing:.12em}}
.uq-card{display:flex;flex-direction:column;gap:10px;padding:26px 24px;background:var(--bg1);border:1px solid rgba(0,0,0,.09);border-radius:14px;text-decoration:none;color:var(--t0);transition:all .2s var(--ease)}
.uq-card:hover{border-color:var(--green);background:rgba(162,204,53,.04);transform:translateY(-2px)}
.uq-card-eyebrow{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--navy);font-family:'Open Sans Condensed','Source Sans 3',sans-serif}
.uq-card-title{font-size:20px;font-weight:700;letter-spacing:-.01em}
.uq-card-desc{font-size:16px;color:var(--t1);line-height:1.55}
.uq-card-arrow{margin-top:8px;font-size:16px;color:var(--navy);font-weight:600}

.uq-second{margin-top:36px;padding:24px 22px;border:1px dashed rgba(0,0,0,.18);border-radius:14px;max-width:680px;margin-left:auto;margin-right:auto}
.uq-second p{font-size:18px;color:var(--t1);line-height:1.65;margin:0 0 14px}
.uq-second-link{display:inline-block;padding:12px 22px;background:transparent;border:1px solid var(--navy);color:var(--navy);border-radius:100px;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:.04em;transition:all .15s}
.uq-second-link:hover{background:var(--navy);color:#fff}

.pg-foot{padding:24px 0;border-top:1px solid rgba(0,0,0,.1)}
.pg-foot-inner{display:flex;align-items:center;justify-content:space-between;gap:20px;max-width:1200px;margin:0 auto;padding:0 56px;width:100%}
.pg-foot-legal{font-size:12px;color:rgba(0,0,0,.5)}
.pg-foot-links{display:flex;align-items:center;gap:20px}
.pg-foot-links a{font-size:12px;color:rgba(0,0,0,.5);text-decoration:none;transition:color .15s}
.pg-foot-links a:hover{color:var(--t0)}
@media(max-width:760px){.pg-foot-inner{padding:0 24px;flex-direction:column;text-align:center}}
</style>

<header class="c-header">
  <div class="c-header-inner">
    <a class="c-header-logo" href="/">
      <img src="/chalik-logo.svg" alt="Chalik and Chalik" style="filter:brightness(0) invert(1)" />
    </a>
  </div>
</header>

<div class="uq-page">
<section class="uq-wrap">
  <span class="uq-eyebrow">{CONFIG.eyebrow}</span>
  <h1 class="uq-h1">{CONFIG.h1}</h1>
  <p class="uq-sub">{CONFIG.sub}</p>

  <div class="uq-cards">
    <a class="uq-card" href={CONFIG.card1.href} target="_blank" rel="noopener">
      <span class="uq-card-eyebrow">{CONFIG.card1.eyebrow}</span>
      <span class="uq-card-title">{CONFIG.card1.title}</span>
      <span class="uq-card-desc">{CONFIG.card1.desc}</span>
      <span class="uq-card-arrow">{CONFIG.card1.cta} →</span>
    </a>
    <a class="uq-card" href={CONFIG.card2.href} target="_blank" rel="noopener">
      <span class="uq-card-eyebrow">{CONFIG.card2.eyebrow}</span>
      <span class="uq-card-title">{CONFIG.card2.title}</span>
      <span class="uq-card-desc">{CONFIG.card2.desc}</span>
      <span class="uq-card-arrow">{CONFIG.card2.cta} →</span>
    </a>
  </div>

  <div class="uq-second">
    <p>{CONFIG.bookAnywayText}</p>
    <a class="uq-second-link" href={bookAnywayLink}>{CONFIG.bookAnywayLinkText}</a>
  </div>
</section>

<footer class="pg-foot">
  <div class="pg-foot-inner">
    <p class="pg-foot-legal">&copy; {CONFIG.year} Chalik &amp; Chalik. All Rights Reserved.</p>
    <div class="pg-foot-links">
      <a href="/privacy-policy">Privacy</a>
      <a href="/terms">Terms</a>
    </div>
  </div>
</footer>
</div>

</BaseLayout>
