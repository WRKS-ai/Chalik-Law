---
// PAGE 4 - THANK YOU (UNQUALIFIED)
// Route: /catalyst/unqualified-slip-and-fall
import BaseLayout from '../../layouts/BaseLayout.astro';

const CONFIG = {
  metaTitle:    "Thank You for Reaching Out | Chalik and Chalik",
  clientDomain: "https://chaliklaw.com",
  verticalSlug: "slip-and-fall",
  clientName:   "Chalik and Chalik",
  fbPixelId:    "",

  eyebrow:  "Thank you for reaching out",
  h1:       "We may not be able to take your case right now.",
  sub:      "Cases from accidents that occurred more than 4 years ago are generally outside the statute of limitations in Florida. Here are some resources that may still help you.",

  card1: {
    eyebrow: "Know Your Rights",
    title:   "Florida Personal Injury Guide",
    desc:    "Understand your legal rights and options after a slip and fall accident in Florida.",
    href:    "#",
    cta:     "Read the guide",
  },
  card2: {
    eyebrow: "Free Legal Help",
    title:   "Florida Bar Referral Service",
    desc:    "The Florida Bar can connect you with attorneys who specialize in your type of case.",
    href:    "https://www.floridabar.org/public/lrs/",
    cta:     "Find an attorney",
  },

  bookAnywayText:     "Think you answered the question incorrectly? No problem. You can still request a review below.",
  bookAnywayLinkText: "Request a case review anyway",
  year:               new Date().getFullYear(),
};

const bookAnywayLink = `/booking/${CONFIG.verticalSlug}`;
---

<BaseLayout
  title={CONFIG.metaTitle}
  description=""
  canonical={`${CONFIG.clientDomain}/catalyst/unqualified-${CONFIG.verticalSlug}`}
  minimalNav={true}
  minimalFooter={true}
  noChat={true}
>

{CONFIG.fbPixelId && (
  <script slot="head" is:inline define:vars={{ pid: CONFIG.fbPixelId }}>
    !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
    fbq('init',pid);fbq('track','PageView');
  </script>
)}

<style is:global>
:root{
  --bg:#ffffff;--bg1:#f7f7f8;--bg2:#eeeeef;
  --t0:#0d0d0d;--t1:#444444;--t2:#888888;
  --pu:#1a3a6b;--pu3:#2563EB;
  --ease:cubic-bezier(.4,0,.2,1);
  --sans:'Inter',system-ui,sans-serif;
}
#nav-bg{display:none!important}
#nav{background:transparent!important;border:0!important;box-shadow:none!important;backdrop-filter:none!important;-webkit-backdrop-filter:none!important}
.nav-minimal .nav-inner{justify-content:center;border:0;background:transparent}
.nav-minimal .nav-logo{margin:0}

.uq-page{min-height:100vh;display:flex;flex-direction:column}
.uq-wrap{flex:1;width:100%;max-width:760px;margin:0 auto;padding:120px 32px 56px;text-align:center;display:flex;flex-direction:column;justify-content:center}
@media(max-width:1024px){.uq-page{min-height:0}.uq-wrap{display:block;padding:130px 32px 60px}}

.uq-eyebrow{display:inline-block;font-size:22px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--pu3);margin-bottom:20px}
.uq-h1{font-size:clamp(28px,4vw,46px);font-weight:700;line-height:1.08;letter-spacing:-.035em;color:var(--t0);margin:0 0 18px}
.uq-sub{font-size:clamp(16px,1.5vw,18px);color:var(--t1);line-height:1.7;max-width:600px;margin:0 auto 44px}

.uq-cards{display:grid;grid-template-columns:1fr 1fr;gap:18px;max-width:680px;margin:0 auto 36px;text-align:left}
@media(max-width:640px){.uq-cards{grid-template-columns:1fr}.uq-eyebrow{font-size:16px;letter-spacing:.12em}}
.uq-card{display:flex;flex-direction:column;gap:10px;padding:26px 24px;background:var(--bg1);border:1px solid rgba(0,0,0,.09);border-radius:14px;text-decoration:none;color:var(--t0);transition:all .2s var(--ease)}
.uq-card:hover{border-color:var(--pu3);background:#eff4ff;transform:translateY(-2px)}
.uq-card-eyebrow{font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--pu3)}
.uq-card-title{font-size:20px;font-weight:700;letter-spacing:-.01em}
.uq-card-desc{font-size:16px;color:var(--t1);line-height:1.55}
.uq-card-arrow{margin-top:8px;font-size:16px;color:var(--pu3);font-weight:600}

.uq-second{margin-top:36px;padding:24px 22px;border:1px dashed rgba(0,0,0,.18);border-radius:14px;max-width:680px;margin-left:auto;margin-right:auto}
.uq-second p{font-size:16px;color:var(--t1);line-height:1.65;margin:0 0 14px}
.uq-second-link{display:inline-block;padding:12px 22px;background:transparent;border:1px solid var(--pu3);color:var(--pu3);border-radius:100px;text-decoration:none;font-size:13px;font-weight:700;letter-spacing:.04em;transition:all .15s}
.uq-second-link:hover{background:var(--pu3);color:#fff}

.pg-foot{padding:24px 0;border-top:1px solid rgba(0,0,0,.1)}
.pg-foot-inner{display:flex;align-items:center;justify-content:space-between;gap:20px;max-width:1200px;margin:0 auto;padding:0 56px;width:100%}
.pg-foot-legal{font-size:12px;color:rgba(0,0,0,.5)}
.pg-foot-links{display:flex;align-items:center;gap:20px}
.pg-foot-links a{font-size:12px;color:rgba(0,0,0,.5);text-decoration:none;transition:color .15s}
.pg-foot-links a:hover{color:var(--t0)}
@media(max-width:760px){.pg-foot-inner{padding:0 24px;flex-direction:column;text-align:center}}
</style>

<div class="uq-page">
<section class="uq-wrap">
  <span class="uq-eyebrow">{CONFIG.eyebrow}</span>
  <h1 class="uq-h1">{CONFIG.h1}</h1>
  <p class="uq-sub">{CONFIG.sub}</p>

  <div class="uq-cards">
    <a class="uq-card" href={CONFIG.card1.href}>
      <span class="uq-card-eyebrow">{CONFIG.card1.eyebrow}</span>
      <span class="uq-card-title">{CONFIG.card1.title}</span>
      <span class="uq-card-desc">{CONFIG.card1.desc}</span>
      <span class="uq-card-arrow">{CONFIG.card1.cta}</span>
    </a>
    <a class="uq-card" href={CONFIG.card2.href}>
      <span class="uq-card-eyebrow">{CONFIG.card2.eyebrow}</span>
      <span class="uq-card-title">{CONFIG.card2.title}</span>
      <span class="uq-card-desc">{CONFIG.card2.desc}</span>
      <span class="uq-card-arrow">{CONFIG.card2.cta}</span>
    </a>
  </div>

  <div class="uq-second">
    <p>{CONFIG.bookAnywayText}</p>
    <a class="uq-second-link" href={bookAnywayLink}>{CONFIG.bookAnywayLinkText}</a>
  </div>
</section>

<footer class="pg-foot">
  <div class="pg-foot-inner">
    <p class="pg-foot-legal">&copy; {CONFIG.year} Chalik &amp; Chalik. All Rights Reserved.</p>
    <div class="pg-foot-links">
      <a href="/privacy-policy">Privacy</a>
      <a href="/terms">Terms</a>
    </div>
  </div>
</footer>
</div>

</BaseLayout>
